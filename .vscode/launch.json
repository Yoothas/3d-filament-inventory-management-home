{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Flask API",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_ENV": "development"
      },
      "args": ["run", "--host=localhost", "--port=5000"],
      "jinja": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Streamlit Dashboard",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": ["run", "dashboard.py", "--logger.level=debug"],
      "console": "integratedTerminal"
    },
    {
      "name": "Python: Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tools/test_postprint.py", "-v"],
      "console": "integratedTerminal"
    }
  ]
}
